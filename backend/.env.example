# ============================================================
# Backend environment template. Copy to `.env` and fill in:
#     cp .env.example .env
# Loaded by api/main.py and create_db.py (via python-dotenv) BEFORE the settings
# singleton is built. The real `.env` is gitignored — never commit it.
# ============================================================

# --- Auth (REQUIRED) ---
# JWT signing secret. MUST be >= 32 chars or the API refuses to boot (see the
# lifespan check in api/main.py). Generate one with:
#     python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# --- Google Vertex AI (REQUIRED — embeddings + Gemini) ---
# GCP project id, and the path to a service-account JSON granted Vertex AI access.
# Without these, embedding/LLM calls fail (see llm/models.py).
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# --- Qdrant Cloud (REQUIRED — vector retrieval) ---
QDRANT_API_KEY=
# Optional: override the vector DB endpoint (defaults to the cluster in settings.py).
# QDRANT_URL=https://your-cluster.gcp.cloud.qdrant.io

# --- Database (optional) ---
# Defaults to a local SQLite file (sqlite:///data/app.db). Point at Postgres in prod.
# DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname

# --- CORS (set in production) ---
# Comma-separated browser origins allowed to call the API. Defaults to the Vite
# dev origin; set your deployed frontend origin(s) here in production.
# CORS_ALLOW_ORIGINS=https://policy.example.com,https://www.policy.example.com

# --- LangSmith tracing (optional) ---
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=rag-travel-policy
