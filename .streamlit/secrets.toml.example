# Streamlit secrets template.
#
# LOCAL: copy this to `.streamlit/secrets.toml` and fill it in (that real file
#        is git-ignored). You normally don't need it locally — the .env file
#        already works.
# CLOUD: on Streamlit Community Cloud, paste the filled-in version into
#        App settings -> Secrets (do NOT commit the real file).
#
# The [gcp_service_account] section is your Project_123.json, field-for-field.

QDRANT_API_KEY = "your-qdrant-cloud-api-key"
GOOGLE_CLOUD_PROJECT = "your-gcp-project-id"

[gcp_service_account]
type = "service_account"
project_id = "your-gcp-project-id"
private_key_id = "..."
# Keep the literal \n escapes inside the quotes, on one line:
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "your-sa@your-project.iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/your-sa%40your-project.iam.gserviceaccount.com"
universe_domain = "googleapis.com"
